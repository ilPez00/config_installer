#!/usr/bin/env bash
# Installs configs, shell, editor, themes, and tools on a fresh Debian install.
# Replicates the look & feel of the source machine (terminal + XFCE desktop).
# Does NOT install heavy packages (IDEs, games, etc.).
set -e

# ─────────────────────────────────────────────────────────────
# Colors
# ─────────────────────────────────────────────────────────────
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

info()  { echo -e "${GREEN}[+]${NC} $1"; }
warn()  { echo -e "${YELLOW}[!]${NC} $1"; }
error() { echo -e "${RED}[✗]${NC} $1"; }

# ─────────────────────────────────────────────────────────────
# Locate configs/ relative to this script
# ─────────────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIGS_DIR="$SCRIPT_DIR/configs"

if [ ! -d "$CONFIGS_DIR" ]; then
    error "configs/ folder not found at $CONFIGS_DIR"
    echo "  Run pack_configs on the source machine first."
    exit 1
fi

USER_NAME="$USER"
HOME_DIR="$HOME"

echo ""
echo "══════════════════════════════════════════"
echo "       DEBIAN CONFIG INSTALLER"
echo "══════════════════════════════════════════"
echo ""
echo "  User:    $USER_NAME"
echo "  Home:    $HOME_DIR"
echo "  Configs: $CONFIGS_DIR"
echo ""
read -p "Continue? (y/N) " -n 1 -r
echo
[[ ! $REPLY =~ ^[Yy]$ ]] && { echo "Aborted."; exit 1; }

# ─────────────────────────────────────────────────────────────
# 0. Bootstrap: install bare minimum tools needed by this script
# ─────────────────────────────────────────────────────────────
info "Installing bootstrap dependencies (git, curl, wget, rsync)"
sudo apt update
sudo apt install -y git curl wget rsync unzip 2>/dev/null || {
    error "Failed to install basic tools. Check your internet connection and /etc/apt/sources.list"
    exit 1
}

# ─────────────────────────────────────────────────────────────
# 1a. Restore APT sources & keys (before update so repos are available)
# ─────────────────────────────────────────────────────────────
if [ -d "$CONFIGS_DIR/apt/sources" ]; then
    info "Restoring APT sources and repository keys"

    # Backup existing sources
    sudo cp -a /etc/apt/sources.list /etc/apt/sources.list.backup 2>/dev/null || true
    [ -d /etc/apt/sources.list.d ] && sudo cp -a /etc/apt/sources.list.d /etc/apt/sources.list.d.backup 2>/dev/null || true

    # Restore sources
    [ -f "$CONFIGS_DIR/apt/sources/sources.list" ] && sudo cp -a "$CONFIGS_DIR/apt/sources/sources.list" /etc/apt/
    [ -d "$CONFIGS_DIR/apt/sources/sources.list.d" ] && sudo cp -a "$CONFIGS_DIR/apt/sources/sources.list.d/"* /etc/apt/sources.list.d/ 2>/dev/null || true

    # Restore preferences
    [ -f "$CONFIGS_DIR/apt/sources/preferences" ] && sudo cp -a "$CONFIGS_DIR/apt/sources/preferences" /etc/apt/
    [ -d "$CONFIGS_DIR/apt/sources/preferences.d" ] && sudo cp -a "$CONFIGS_DIR/apt/sources/preferences.d" /etc/apt/

    # Restore GPG keys (legacy method)
    [ -f "$CONFIGS_DIR/apt/keys/trusted-keys.gpg" ] && sudo apt-key add "$CONFIGS_DIR/apt/keys/trusted-keys.gpg" 2>/dev/null || true
    [ -f "$CONFIGS_DIR/apt/keys/trusted.gpg" ] && sudo cp -a "$CONFIGS_DIR/apt/keys/trusted.gpg" /etc/apt/ 2>/dev/null || true
    [ -d "$CONFIGS_DIR/apt/keys/trusted.gpg.d" ] && sudo cp -a "$CONFIGS_DIR/apt/keys/trusted.gpg.d/"* /etc/apt/trusted.gpg.d/ 2>/dev/null || true

    # Restore keyrings (modern method)
    if [ -d "$CONFIGS_DIR/apt/keys/keyrings" ]; then
        sudo mkdir -p /usr/share/keyrings
        sudo cp -a "$CONFIGS_DIR/apt/keys/keyrings/"* /usr/share/keyrings/ 2>/dev/null || true
    fi

    info "  APT sources, keys, and keyrings restored"
    warn "  Review /etc/apt/sources.list — mirror URLs may need updating for this machine"
else
    warn "No APT sources found in configs, using system defaults"
fi

# ─────────────────────────────────────────────────────────────
# 1b. System update & essential packages
# ─────────────────────────────────────────────────────────────
info "Updating system"
sudo apt update && sudo apt upgrade -y

info "Installing essential packages"
sudo apt install -y \
    zsh \
    zsh-autosuggestions \
    zsh-syntax-highlighting \
    micro \
    fastfetch neofetch \
    htop btop \
    lsd bat fd-find \
    ranger \
    fzf \
    zoxide \
    thefuck \
    direnv \
    yt-dlp \
    papirus-icon-theme \
    2>/dev/null || warn "Some packages may not be available in your repos"

# Nerd Fonts: download manually if not available via apt
if ! fc-list | grep -qi "MesloLG"; then
    info "Downloading MesloLGS Nerd Font (for Powerlevel10k)"
    mkdir -p ~/.local/share/fonts
    cd /tmp
    for font in "MesloLGS NF Regular" "MesloLGS NF Bold" "MesloLGS NF Italic" "MesloLGS NF Bold Italic"; do
        fname="${font// /%20}.ttf"
        wget -q "https://github.com/romkatv/powerlevel10k-media/raw/master/${fname}" \
            -O "$HOME_DIR/.local/share/fonts/${font}.ttf" 2>/dev/null || true
    done
    fc-cache -f 2>/dev/null || true
fi

# ─────────────────────────────────────────────────────────────
# 2. Oh My Zsh + Powerlevel10k
# ─────────────────────────────────────────────────────────────
if [ ! -d "$HOME_DIR/.oh-my-zsh" ]; then
    info "Installing Oh My Zsh"
    RUNZSH=no CHSH=no sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
else
    warn "Oh My Zsh already installed, skipping"
fi

if [ ! -d "$HOME_DIR/.oh-my-zsh/custom/themes/powerlevel10k" ]; then
    info "Installing Powerlevel10k theme"
    git clone --depth=1 https://github.com/romkatv/powerlevel10k.git \
        "$HOME_DIR/.oh-my-zsh/custom/themes/powerlevel10k"
else
    warn "Powerlevel10k already installed, skipping"
fi

# ─────────────────────────────────────────────────────────────
# 3. Shell configs (.zshrc, .p10k.zsh, .bashrc)
# ─────────────────────────────────────────────────────────────
info "Installing shell configs"

for dotfile in .zshrc .p10k.zsh .bashrc; do
    if [ -f "$CONFIGS_DIR/home/$dotfile" ]; then
        if [ -f "$HOME_DIR/$dotfile" ]; then
            cp "$HOME_DIR/$dotfile" "$HOME_DIR/${dotfile}.backup.$(date +%Y%m%d)" 2>/dev/null || true
        fi
        cp "$CONFIGS_DIR/home/$dotfile" "$HOME_DIR/$dotfile"
        info "  Copied: $dotfile"
    fi
done

# ─────────────────────────────────────────────────────────────
# 4. Micro editor (config + colorscheme)
# ─────────────────────────────────────────────────────────────
info "Configuring Micro editor"
mkdir -p "$HOME_DIR/.config/micro/colorschemes"

if [ -d "$CONFIGS_DIR/config/micro" ]; then
    cp -a "$CONFIGS_DIR/config/micro/settings.json"   "$HOME_DIR/.config/micro/" 2>/dev/null || true
    cp -a "$CONFIGS_DIR/config/micro/bindings.json"    "$HOME_DIR/.config/micro/" 2>/dev/null || true
    cp -a "$CONFIGS_DIR/config/micro/colorschemes/"*   "$HOME_DIR/.config/micro/colorschemes/" 2>/dev/null || true
    info "  Micro: settings, bindings, colorscheme copied"
fi

# ─────────────────────────────────────────────────────────────
# 5. Fastfetch config
# ─────────────────────────────────────────────────────────────
info "Configuring Fastfetch"
mkdir -p "$HOME_DIR/.config/fastfetch"

if [ -f "$CONFIGS_DIR/config/fastfetch/config.jsonc" ]; then
    cp "$CONFIGS_DIR/config/fastfetch/config.jsonc" "$HOME_DIR/.config/fastfetch/"
    info "  Fastfetch config copied"
fi

# ─────────────────────────────────────────────────────────────
# 6. XFCE4 desktop config
# ─────────────────────────────────────────────────────────────
if [ -d "$CONFIGS_DIR/config/xfce4" ]; then
    info "Configuring XFCE4"
    mkdir -p "$HOME_DIR/.config/xfce4"
    rsync -a "$CONFIGS_DIR/config/xfce4/" "$HOME_DIR/.config/xfce4/"
    info "  XFCE4: panels, shortcuts, window manager copied"
fi

# ─────────────────────────────────────────────────────────────
# 6b. Autostart & Thunar
# ─────────────────────────────────────────────────────────────
if [ -d "$CONFIGS_DIR/config/autostart" ]; then
    info "Autostart entries"
    mkdir -p "$HOME_DIR/.config/autostart"
    cp -a "$CONFIGS_DIR/config/autostart/"* "$HOME_DIR/.config/autostart/" 2>/dev/null || true
fi

if [ -d "$CONFIGS_DIR/config/Thunar" ]; then
    info "Thunar file manager config"
    mkdir -p "$HOME_DIR/.config/Thunar"
    rsync -a "$CONFIGS_DIR/config/Thunar/" "$HOME_DIR/.config/Thunar/"
fi

# ─────────────────────────────────────────────────────────────
# 7. GTK themes, icons, cursors
# ─────────────────────────────────────────────────────────────
info "Installing themes, icons, cursors"

if [ -d "$CONFIGS_DIR/themes" ]; then
    mkdir -p "$HOME_DIR/.themes"
    rsync -a "$CONFIGS_DIR/themes/" "$HOME_DIR/.themes/"
    info "  GTK themes copied"
fi

if [ -d "$CONFIGS_DIR/icons" ]; then
    mkdir -p "$HOME_DIR/.icons"
    rsync -a "$CONFIGS_DIR/icons/" "$HOME_DIR/.icons/"
    info "  Icons copied"
fi

if [ -d "$CONFIGS_DIR/local-icons" ]; then
    mkdir -p "$HOME_DIR/.local/share/icons"
    rsync -a "$CONFIGS_DIR/local-icons/" "$HOME_DIR/.local/share/icons/"
    info "  Extra icons copied (.local/share)"
fi

if [ -d "$CONFIGS_DIR/config/gtk-3.0" ]; then
    mkdir -p "$HOME_DIR/.config/gtk-3.0"
    cp -a "$CONFIGS_DIR/config/gtk-3.0/"* "$HOME_DIR/.config/gtk-3.0/" 2>/dev/null || true
    info "  GTK-3.0 settings copied"
fi

if [ -d "$CONFIGS_DIR/config/gtk-4.0" ]; then
    mkdir -p "$HOME_DIR/.config/gtk-4.0"
    cp -a "$CONFIGS_DIR/config/gtk-4.0/"* "$HOME_DIR/.config/gtk-4.0/" 2>/dev/null || true
fi

# ─────────────────────────────────────────────────────────────
# 8. User fonts
# ─────────────────────────────────────────────────────────────
if [ -d "$CONFIGS_DIR/fonts" ]; then
    info "Installing user fonts"
    mkdir -p "$HOME_DIR/.local/share/fonts"
    rsync -a "$CONFIGS_DIR/fonts/" "$HOME_DIR/.local/share/fonts/"
    fc-cache -f 2>/dev/null || true
    info "  Fonts copied and cache updated"
fi

# ─────────────────────────────────────────────────────────────
# 9. LightDM config (if present)
# ─────────────────────────────────────────────────────────────
if [ -d "$CONFIGS_DIR/lightdm" ]; then
    info "Configuring LightDM"
    sudo cp -a "$CONFIGS_DIR/lightdm/"* /etc/lightdm/ 2>/dev/null || true
    info "  LightDM greeter config copied"
fi

# ─────────────────────────────────────────────────────────────
# 9b. Sudoers config
# ─────────────────────────────────────────────────────────────
if [ -d "$CONFIGS_DIR/system/sudoers.d" ] && ls "$CONFIGS_DIR/system/sudoers.d/"* &>/dev/null; then
    info "Restoring sudoers.d rules"
    for rule in "$CONFIGS_DIR/system/sudoers.d/"*; do
        filename=$(basename "$rule")
        # Validate syntax before installing (broken sudoers = locked out)
        if visudo -cf "$rule" &>/dev/null; then
            sudo cp "$rule" /etc/sudoers.d/"$filename"
            sudo chmod 0440 /etc/sudoers.d/"$filename"
            info "  Installed: /etc/sudoers.d/$filename"
        else
            warn "  Skipped $filename — failed syntax check (visudo -c)"
        fi
    done
fi

# ─────────────────────────────────────────────────────────────
# 9c. Sysctl (kernel params)
# ─────────────────────────────────────────────────────────────
if [ -f "$CONFIGS_DIR/system/sysctl.conf" ] || ls "$CONFIGS_DIR/system/sysctl.d/"*.conf &>/dev/null 2>&1; then
    info "Restoring sysctl config"
    [ -f "$CONFIGS_DIR/system/sysctl.conf" ] && sudo cp -a "$CONFIGS_DIR/system/sysctl.conf" /etc/sysctl.conf
    if [ -d "$CONFIGS_DIR/system/sysctl.d" ]; then
        sudo mkdir -p /etc/sysctl.d
        sudo cp -a "$CONFIGS_DIR/system/sysctl.d/"*.conf /etc/sysctl.d/ 2>/dev/null || true
    fi
    sudo sysctl --system 2>/dev/null || true
    info "  Sysctl params applied"
fi

# ─────────────────────────────────────────────────────────────
# 9d. System-wide environment & shell configs
# ─────────────────────────────────────────────────────────────
if [ -d "$CONFIGS_DIR/system/environment" ]; then
    info "Restoring system environment"
    [ -f "$CONFIGS_DIR/system/environment/environment" ] && sudo cp -a "$CONFIGS_DIR/system/environment/environment" /etc/environment
    [ -f "$CONFIGS_DIR/system/environment/profile" ] && sudo cp -a "$CONFIGS_DIR/system/environment/profile" /etc/profile
    [ -d "$CONFIGS_DIR/system/environment/profile.d" ] && sudo cp -a "$CONFIGS_DIR/system/environment/profile.d/"* /etc/profile.d/ 2>/dev/null || true
    # System shell configs
    [ -d "$CONFIGS_DIR/system/environment/zsh" ] && sudo cp -a "$CONFIGS_DIR/system/environment/zsh" /etc/ 2>/dev/null || true
    [ -f "$CONFIGS_DIR/system/environment/zshrc" ] && sudo cp -a "$CONFIGS_DIR/system/environment/zshrc" /etc/zshrc 2>/dev/null || true
    [ -f "$CONFIGS_DIR/system/environment/bash.bashrc" ] && sudo cp -a "$CONFIGS_DIR/system/environment/bash.bashrc" /etc/bash.bashrc 2>/dev/null || true
    info "  /etc/environment, /etc/profile, shell configs restored"
fi

# ─────────────────────────────────────────────────────────────
# 9e. Systemd user units
# ─────────────────────────────────────────────────────────────
if [ -d "$CONFIGS_DIR/system/systemd-user" ] && ls "$CONFIGS_DIR/system/systemd-user/"* &>/dev/null; then
    info "Restoring systemd user units"
    mkdir -p "$HOME_DIR/.config/systemd/user"
    rsync -a "$CONFIGS_DIR/system/systemd-user/" "$HOME_DIR/.config/systemd/user/"
    systemctl --user daemon-reload 2>/dev/null || true
    info "  Systemd user units copied and daemon reloaded"
fi

# ─────────────────────────────────────────────────────────────
# 10. Wallpapers
# ─────────────────────────────────────────────────────────────
if [ -d "$CONFIGS_DIR/wallpapers" ]; then
    info "Copying wallpapers"
    mkdir -p "$HOME_DIR/Pictures/Wallpapers"
    rsync -a "$CONFIGS_DIR/wallpapers/" "$HOME_DIR/Pictures/Wallpapers/"
fi

# ─────────────────────────────────────────────────────────────
# 11. Git config
# ─────────────────────────────────────────────────────────────
if [ -f "$CONFIGS_DIR/home/.gitconfig" ]; then
    info "Git config"
    cp "$CONFIGS_DIR/home/.gitconfig" "$HOME_DIR/.gitconfig"
    warn "  Remember to update name/email in ~/.gitconfig!"
fi

# ─────────────────────────────────────────────────────────────
# 12. Set Zsh as default shell
# ─────────────────────────────────────────────────────────────
if [ "$SHELL" != "$(which zsh)" ]; then
    info "Setting Zsh as default shell"
    chsh -s "$(which zsh)" || warn "Run manually: chsh -s $(which zsh)"
fi

# ─────────────────────────────────────────────────────────────
# 13. Rebuild caches
# ─────────────────────────────────────────────────────────────
info "Rebuilding caches"
fc-cache -f 2>/dev/null || true
gtk-update-icon-cache ~/.local/share/icons/* 2>/dev/null || true
gtk-update-icon-cache ~/.icons/* 2>/dev/null || true

echo ""
echo "══════════════════════════════════════════"
echo "          SETUP COMPLETE!"
echo "══════════════════════════════════════════"
echo ""
echo "  Installed:"
echo "    - Zsh + Oh My Zsh + Powerlevel10k"
echo "    - Micro editor + colorscheme"
echo "    - Fastfetch"
echo "    - lsd, bat, fd, ranger, fzf, zoxide, thefuck"
echo "    - GTK themes, icons, cursors"
echo "    - XFCE4 desktop config"
echo "    - Fonts (MesloLGS Nerd Font)"
echo ""
echo "  To do:"
echo "    - Update name/email in ~/.gitconfig"
echo "    - Log out and back in"
echo "    - On first zsh launch: Powerlevel10k will run its wizard"
echo "      (or use the copied .p10k.zsh config)"
echo ""
