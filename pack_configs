#!/usr/bin/env bash
# Packs configs from THIS machine into a configs/ folder.
# Run on the SOURCE machine, then copy configs/ to a USB drive or use install_configs on the target.
set -e

GREEN='\033[0;32m'
NC='\033[0m'
info() { echo -e "${GREEN}[+]${NC} $1"; }

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OUT="$SCRIPT_DIR/configs"

echo ""
echo "══════════════════════════════════════════"
echo "       PACK CONFIGS — source machine"
echo "══════════════════════════════════════════"
echo "  Output: $OUT"
echo ""

rm -rf "$OUT"
mkdir -p \
    "$OUT/home" \
    "$OUT/config/micro/colorschemes" \
    "$OUT/config/fastfetch" \
    "$OUT/config/xfce4" \
    "$OUT/config/gtk-3.0" \
    "$OUT/config/gtk-4.0" \
    "$OUT/themes" \
    "$OUT/icons" \
    "$OUT/local-icons" \
    "$OUT/fonts" \
    "$OUT/lightdm" \
    "$OUT/wallpapers" \
    "$OUT/apt/sources" \
    "$OUT/apt/keys" \
    "$OUT/system/sudoers.d" \
    "$OUT/system/sysctl.d" \
    "$OUT/system/systemd-user" \
    "$OUT/system/environment"

# ── Shell dotfiles ──
info "Shell dotfiles"
for f in .zshrc .p10k.zsh .bashrc .gitconfig .selected_editor; do
    [ -f ~/"$f" ] && cp ~/"$f" "$OUT/home/" && echo "    $f"
done

# ── Micro editor ──
info "Micro editor config"
[ -f ~/.config/micro/settings.json ] && cp ~/.config/micro/settings.json "$OUT/config/micro/"
[ -f ~/.config/micro/bindings.json ] && cp ~/.config/micro/bindings.json "$OUT/config/micro/"
cp ~/.config/micro/colorschemes/* "$OUT/config/micro/colorschemes/" 2>/dev/null || true

# ── Fastfetch ──
info "Fastfetch config"
[ -f ~/.config/fastfetch/config.jsonc ] && cp ~/.config/fastfetch/config.jsonc "$OUT/config/fastfetch/"

# ── XFCE4 ──
info "XFCE4 config"
if [ -d ~/.config/xfce4 ]; then
    rsync -a \
        --exclude="*cache*" \
        --exclude="*Cache*" \
        ~/.config/xfce4/ "$OUT/config/xfce4/"
fi

# ── Autostart ──
info "Autostart entries"
if [ -d ~/.config/autostart ]; then
    mkdir -p "$OUT/config/autostart"
    cp -a ~/.config/autostart/* "$OUT/config/autostart/" 2>/dev/null || true
fi

# ── Thunar file manager ──
info "Thunar config"
if [ -d ~/.config/Thunar ]; then
    mkdir -p "$OUT/config/Thunar"
    rsync -a ~/.config/Thunar/ "$OUT/config/Thunar/"
fi

# ── GTK settings ──
info "GTK settings"
[ -d ~/.config/gtk-3.0 ] && cp -a ~/.config/gtk-3.0/* "$OUT/config/gtk-3.0/" 2>/dev/null || true
[ -d ~/.config/gtk-4.0 ] && cp -a ~/.config/gtk-4.0/* "$OUT/config/gtk-4.0/" 2>/dev/null || true

# ── GTK Themes ──
info "GTK themes"
if [ -d ~/.themes ]; then
    find ~/.themes -maxdepth 1 -mindepth 1 -type d | while read -r dir; do
        rsync -a "$dir" "$OUT/themes/"
        echo "    $(basename "$dir")"
    done
fi

# ── Icons ──
info "Icons (~/.icons)"
if [ -d ~/.icons ]; then
    rsync -a ~/.icons/ "$OUT/icons/"
fi

info "Icons (.local/share/icons)"
if [ -d ~/.local/share/icons ]; then
    rsync -a ~/.local/share/icons/ "$OUT/local-icons/"
fi

# ── Fonts ──
info "User fonts"
if [ -d ~/.local/share/fonts ]; then
    rsync -a ~/.local/share/fonts/ "$OUT/fonts/"
fi

# ── LightDM ──
info "LightDM config"
sudo cp -a /etc/lightdm/lightdm.conf "$OUT/lightdm/" 2>/dev/null || true
sudo cp -a /etc/lightdm/lightdm-gtk-greeter.conf "$OUT/lightdm/" 2>/dev/null || true
[ -d /etc/lightdm/lightdm.conf.d ] && sudo cp -a /etc/lightdm/lightdm.conf.d "$OUT/lightdm/" 2>/dev/null || true

# ── Wallpapers (lightweight, max 20) ──
info "Wallpapers"
if [ -d ~/Pictures/Wallpapers ]; then
    find ~/Pictures/Wallpapers -type f \( -name "*.jpg" -o -name "*.png" \) | head -20 | while read -r wp; do
        cp "$wp" "$OUT/wallpapers/" 2>/dev/null || true
    done
fi

# ── APT sources & keys ──
info "APT sources and repository keys"
sudo cp -a /etc/apt/sources.list "$OUT/apt/sources/" 2>/dev/null || true
[ -d /etc/apt/sources.list.d ] && sudo cp -a /etc/apt/sources.list.d "$OUT/apt/sources/" 2>/dev/null || true
[ -f /etc/apt/preferences ] && sudo cp -a /etc/apt/preferences "$OUT/apt/sources/" 2>/dev/null || true
[ -d /etc/apt/preferences.d ] && sudo cp -a /etc/apt/preferences.d "$OUT/apt/sources/" 2>/dev/null || true

# GPG keys for repos
sudo apt-key exportall > "$OUT/apt/keys/trusted-keys.gpg" 2>/dev/null || true
[ -f /etc/apt/trusted.gpg ] && sudo cp -a /etc/apt/trusted.gpg "$OUT/apt/keys/" 2>/dev/null || true
[ -d /etc/apt/trusted.gpg.d ] && sudo cp -a /etc/apt/trusted.gpg.d "$OUT/apt/keys/" 2>/dev/null || true
# Keyrings from /usr/share (modern method)
if [ -d /usr/share/keyrings ]; then
    mkdir -p "$OUT/apt/keys/keyrings"
    sudo cp -a /usr/share/keyrings/*.gpg "$OUT/apt/keys/keyrings/" 2>/dev/null || true
    sudo cp -a /usr/share/keyrings/*.asc "$OUT/apt/keys/keyrings/" 2>/dev/null || true
fi

# Manually installed package list (for reference)
info "APT package lists"
apt-mark showmanual > "$OUT/apt/manual-packages.list" 2>/dev/null || true

# ── Sudoers config ──
info "Sudoers config"
# Only custom rules in sudoers.d, never the main /etc/sudoers (security risk)
if [ -d /etc/sudoers.d ]; then
    sudo cp -a /etc/sudoers.d/* "$OUT/system/sudoers.d/" 2>/dev/null || true
fi

# ── Sysctl (kernel params) ──
info "Sysctl config"
[ -f /etc/sysctl.conf ] && sudo cp -a /etc/sysctl.conf "$OUT/system/" 2>/dev/null || true
if [ -d /etc/sysctl.d ]; then
    sudo cp -a /etc/sysctl.d/*.conf "$OUT/system/sysctl.d/" 2>/dev/null || true
fi

# ── System-wide environment ──
info "System environment"
[ -f /etc/environment ] && sudo cp -a /etc/environment "$OUT/system/environment/" 2>/dev/null || true
[ -f /etc/profile ] && sudo cp -a /etc/profile "$OUT/system/environment/" 2>/dev/null || true
[ -d /etc/profile.d ] && sudo cp -a /etc/profile.d "$OUT/system/environment/" 2>/dev/null || true
# Shell-level system configs
sudo cp -a /etc/{zsh,zshrc,bash.bashrc} "$OUT/system/environment/" 2>/dev/null || true
[ -d /etc/bashrc.d ] && sudo cp -a /etc/bashrc.d "$OUT/system/environment/" 2>/dev/null || true

# ── Systemd user units ──
info "Systemd user units"
if [ -d ~/.config/systemd/user ]; then
    rsync -a ~/.config/systemd/user/ "$OUT/system/systemd-user/" 2>/dev/null || true
fi

# ── Summary ──
echo ""
SIZE=$(du -sh "$OUT" | cut -f1)
echo "══════════════════════════════════════════"
echo "  Pack complete: $OUT"
echo "  Size: $SIZE"
echo "══════════════════════════════════════════"
echo ""
echo "  Next steps:"
echo "    1. Copy this folder to a USB drive"
echo "    2. On the target machine:"
echo "       cd /media/.../config_installer"
echo "       bash install_configs"
echo ""
